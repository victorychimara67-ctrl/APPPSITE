PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret
SITE_URL=https://emmanuelciuniverse.com
ADMIN_EMAILS=owner@example.com

# Vercel is read-only. Keep false in production; local dev can use true.
FILE_DB_WRITES=true

# Stripe Checkout
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Create a private token in the Printful Developer Portal.
# Required scopes depend on what you use, but products/read and orders/write are the key ones here.
PRINTFUL_TOKEN=

# Only needed if your Printful token is account-level instead of store-level.
PRINTFUL_STORE_ID=

# Keep false while testing. true confirms orders and can charge your Printful billing method.
PRINTFUL_AUTO_CONFIRM=false

# Optional: map local products to your Printful sync variant IDs.
PRINTFUL_VARIANT_hoodie=
PRINTFUL_VARIANT_tee=
PRINTFUL_VARIANT_jacket=
PRINTFUL_VARIANT_cap=
PRINTFUL_VARIANT_pants=
PRINTFUL_VARIANT_sneakers=
